#include <behaviors.dtsi>
#include <zmk-helpers/helper.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>
#ifdef CONFIG_WIRELESS
  #include <dt-bindings/zmk/bt.h>
  #include <dt-bindings/zmk/outputs.h>
#endif

#define DEF 0
#define CURSOR 1
#define SYMBOL 2
#define LOWER 3
#define MOUSE 4
#define MOUSE_SLOW 5
#define MOUSE_FAST 6
#define MOUSE_WARP 7
#define MAGIC 8
#define GAMING 9

#define XXX &none
#define ___ &trans

/* Global defaults */

#define QUICK_TAP_MS 175

&sk {
  release-after-ms = <900>;
  quick-release;
};

&sl { // Allow sticky mods to chord across sticky layers.
  ignore-modifiers;
};

&lt {
  flavor = "balanced";
  tapping-term-ms = <200>;
  quick-tap-ms = <QUICK_TAP_MS>;
};

/* Homerow mods — urob's timeless HRM setup */

#define KEYS_L LT0 LT1 LT2 LT3 LT4 LM0 LM1 LM2 LM3 LM4 LB0 LB1 LB2 LB3 LB4
#define KEYS_R RT0 RT1 RT2 RT3 RT4 RM0 RM1 RM2 RM3 RM4 RB0 RB1 RB2 RB3 RB4
#ifndef LH2
  #define THUMBS LH1 LH0 RH0 RH1         // Thumbs on 34 keys.
#else
  #define THUMBS LH2 LH1 LH0 RH0 RH1 RH2 // Thumbs on 36+ keys.
#endif

#define MAKE_HRM(NAME, HOLD, TAP, TRIGGER_POS)                                 \
  ZMK_HOLD_TAP(NAME, bindings = <HOLD>, <TAP>; flavor = "balanced";            \
               tapping-term-ms = <280>; quick-tap-ms = <QUICK_TAP_MS>;         \
               require-prior-idle-ms = <150>; hold-trigger-on-release;         \
               hold-trigger-key-positions = <TRIGGER_POS>;)

MAKE_HRM(hml, &kp, &kp, KEYS_R THUMBS) // Left-hand HRMs.
MAKE_HRM(hmr, &kp, &kp, KEYS_L THUMBS) // Right-hand HRMs.

// Hack: Make HRM combos tap-only (cf, ZMK issue #544).
#define ZMK_COMBO_8(NAME, TAP, POS, LAYERS, COMBO_MS, IDLE_MS, HOLD, SIDE)     \
  MAKE_HRM(hm_combo_##NAME, &kp, TAP, SIDE THUMBS)                             \
  ZMK_COMBO_6(NAME, &hm_combo_##NAME HOLD 0, POS, LAYERS, COMBO_MS, IDLE_MS)

/* Combos and mouse */

#include "combos.dtsi" // Must be sourced after HRM-combo hack.
// #include "leader.dtsi"  // Urob leader key — uncomment to explore later.
#include "mouse.dtsi"

/* Custom behaviors */

// CAPSWord: hold = shift, tap = caps_word.
ZMK_HOLD_TAP(caps_word_ht, bindings = <&kp>, <&caps_word>;
             tapping-term-ms = <200>;)

// Thumb hold-taps (from TailorKey).
ZMK_HOLD_TAP(thumb_ht, bindings = <&mo>, <&kp>; flavor = "balanced";
             tapping-term-ms = <200>; quick-tap-ms = <300>;)
ZMK_HOLD_TAP(space_ht, bindings = <&mo>, <&kp>; flavor = "balanced";
             tapping-term-ms = <200>; quick-tap-ms = <150>;)

// Symbol layer: double-dot macro.
ZMK_MACRO(symb_dotdot, bindings = <&kp DOT &kp DOT>; wait-ms = <0>; tap-ms = <0>;)

// Cursor helper macros.
ZMK_MACRO(cur_extend_line, bindings = <&kp LS(END)>; wait-ms = <1>; tap-ms = <1>;)
ZMK_MACRO(cur_extend_word, bindings = <&kp LC(LS(RIGHT))>; wait-ms = <1>; tap-ms = <1>;)
ZMK_MACRO(cur_select_line, bindings = <&kp HOME &kp LS(END)>; wait-ms = <1>; tap-ms = <1>;)
ZMK_MACRO(cur_select_none, bindings = <&kp DOWN &kp UP &kp RIGHT &kp LEFT>; wait-ms = <1>; tap-ms = <1>;)
ZMK_MACRO(cur_select_word, bindings = <&kp LC(LEFT) &kp LC(LS(RIGHT))>; wait-ms = <1>; tap-ms = <1>;)

// Magic key: just a layer momentary.
// (RGB_STATUS is Glove80/MoErgo-specific, not available in upstream ZMK.)

/* 80 transparent keys for mouse speed sub-layers */
#define LAYER_TRANSPARENT80                                                     \
    ___ ___ ___ ___ ___                             ___ ___ ___ ___ ___         \
    ___ ___ ___ ___ ___ ___                   ___ ___ ___ ___ ___ ___           \
    ___ ___ ___ ___ ___ ___                   ___ ___ ___ ___ ___ ___           \
    ___ ___ ___ ___ ___ ___                   ___ ___ ___ ___ ___ ___           \
    ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___ ___     \
    ___ ___ ___ ___ ___     ___ ___ ___ ___ ___ ___     ___ ___ ___ ___ ___

/* Keymap */

#ifndef ZMK_BASE_LAYER
  #define ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)                 \
      ZMK_LAYER(name, LT RT LM RM LB RB LH RH)
#endif

ZMK_BASE_LAYER(Base,
//╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
    &kp Q         &kp W         &kp F         &kp P         &kp B       ,   &kp J         &kp L         &kp U         &kp Y         &kp RA(L)   ,
//├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
    &hml LGUI A   &hml LALT R   &hml LCTRL S  &hml LSHFT T  &kp G       ,   &kp M         &hmr RSHFT N  &hmr RCTRL E  &hmr LALT I   &hmr RGUI O ,
//├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
    &kp Z         &kp X         &kp C         &kp D         &kp V       ,   &kp K         &kp H         &kp COMMA     &kp DOT       &kp FSLH    ,
//╰─────────────┼─────────────┴─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┴───────────────────────────╯
                              &thumb_ht CURSOR BSPC &kp DEL              ,   &thumb_ht MOUSE RET &space_ht SYMBOL SPACE
//                                          ╰─────────────┴─────────────╯ ╰─────────────┴─────────────╯
)

